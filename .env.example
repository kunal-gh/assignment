# AI Resume Screener Environment Variables

# OpenAI API Configuration
# Required for generating LLM-based ranking explanations
OPENAI_API_KEY=your_openai_api_key_here

# Application Settings
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:8501,https://yourdomain.com

# Model Configuration
# all-MiniLM-L6-v2 is the recommended balance of speed and quality
DEFAULT_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Security (for JWT/Auth if enabled)
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60